generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum StarterType {
  VFD
  SD
  DOL
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())
  entries      Entry[]
}

model CompanyProfile {
  id                 String   @id @default(cuid())
  companyName        String
  area               String
  district           String
  state              String
  pincode            String
  overallConsumption Float
  updatedAt          DateTime @updatedAt
}

model ZoneTag {
  id          String   @id @default(cuid())
  name        String
  
  v1          Float?
  v2          Float?
  v3          Float?
  uhtd1       Float?
  uhtd2       Float?
  uhtd3       Float?
  i1          Float?
  i2          Float?
  i3          Float?
  ihtd1       Float?
  ihtd2       Float?
  ihtd3       Float?
  pf          Float?
  pqName      String?
  description String?
  
  kvarD       Float?
  kvarQ       Float?
  kvarLeadLag String?
  totalPower  Float?

  createdAt   DateTime @default(now())
  areas       AreaTag[]
}

model AreaTag {
  id          String   @id @default(cuid())
  zoneId      String
  zone        ZoneTag  @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name        String
  
  pqName      String?
  v1          Float?
  v2          Float?
  v3          Float?
  uhtd1       Float?
  uhtd2       Float?
  uhtd3       Float?
  i1          Float?
  i2          Float?
  i3          Float?
  ihtd1       Float?
  ihtd2       Float?
  ihtd3       Float?
  pf          Float?
  kvarD       Float?
  kvarQ       Float?
  kvarLeadLag String?
  totalPower  Float?
  description String?

  createdAt   DateTime @default(now())
  entries     Entry[]
}

model Entry {
  id              String      @id @default(cuid())
  areaId          String
  area            AreaTag     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  machineTag      String
  starterType     StarterType
  
  ratedKw         Float
  ratedHp         Float?
  voltage         Float?
  current         Float?
  kva             Float?
  pf              Float?
  kvar            Float?
  measuredKw      Float
  
  calculatedPower Float
  loadFactor      Float
  description     String?
  
  createdAt       DateTime    @default(now())
  createdById     String
  createdBy       User        @relation(fields: [createdById], references: [id])

  @@index([areaId, createdAt])
}
